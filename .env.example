# AgentShadow Community Edition configuration (APP_* prefix, consistent with the Valo ecosystem)

APP_LOG_LEVEL=INFO
APP_CORS_ALLOWED_ORIGINS=*

# Edition gating. "community" (default) locks runtime connectors, PDF reports and
# the correlation feed behind an upgrade. Set to "pro" or "enterprise" to unlock.
APP_EDITION=community
APP_UPGRADE_URL=http://localhost:3011/pricing

# Access control. Set one or more comma-separated keys to lock down the API
# (every endpoint except /health then requires an `X-API-Key` header). Leave
# empty to run open (local dev / demo). The frontend reads NEXT_PUBLIC_API_KEY.
APP_API_KEYS=
# APP_AUTH_ENABLED=true   # set false to force-disable auth even with keys set

# Correlation engine integration (Enterprise; disabled in Community)
APP_CORRELATION_ENGINE_ENABLED=false
APP_CORRELATION_ENGINE_URL=http://correlation:8100
APP_CORRELATION_ENGINE_SECRET=agentshadow-shared-dev-secret
APP_CORRELATION_SOURCE_SLUG=agentshadow

# Optional: live OpenAI Assistants runtime discovery (Pro; mock fleet used if unset)
# OPENAI_API_KEY=sk-...

# Frontend -> backend base URL (build arg for the Next.js image)
NEXT_PUBLIC_API_URL=http://localhost:8013
# Must match one of APP_API_KEYS when access control is enabled.
NEXT_PUBLIC_API_KEY=
# Edition surfaced in the UI (badges, upgrade CTAs).
NEXT_PUBLIC_EDITION=community
NEXT_PUBLIC_UPGRADE_URL=/pricing
